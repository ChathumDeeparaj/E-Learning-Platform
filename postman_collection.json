{
  "info": {
    "name": "EduCloud API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@test.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/courses",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "courses"]
            }
          }
        },
        {
          "name": "Create Course (Multipart)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_INSTRUCTOR_TOKEN"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "New Course",
                  "type": "text"
                },
                {
                  "key": "description",
                  "value": "Course Description",
                  "type": "text"
                },
                {
                  "key": "category",
                  "value": "Programming",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/courses",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "courses"]
            }
          }
        },
        {
          "name": "Enroll in Course",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_STUDENT_TOKEN"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/courses/COURSE_ID/enroll",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "courses", "COURSE_ID", "enroll"]
            }
          }
        }
      ]
    },
    {
      "name": "Quizzes",
      "item": [
        {
          "name": "Create Quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_INSTRUCTOR_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"courseId\": \"COURSE_ID\",\n  \"title\": \"Sample Quiz\",\n  \"questions\": [\n    {\n      \"question\": \"Question 1?\",\n      \"options\": [\"A\", \"B\", \"C\", \"D\"],\n      \"correctAnswer\": 0\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/quizzes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "quizzes"]
            }
          }
        },
        {
          "name": "Submit Quiz",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_STUDENT_TOKEN"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": [0]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/quizzes/QUIZ_ID/submit",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "quizzes", "QUIZ_ID", "submit"]
            }
          }
        }
      ]
    }
  ]
}
